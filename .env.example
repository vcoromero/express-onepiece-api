# ===================
# APPLICATION
# ===================
NODE_ENV=development
PORT=3000

# ===================
# DATABASE (PostgreSQL)
# ===================
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/onepiece_db?schema=public"

# Individual PostgreSQL connection (for pool/raw queries if needed)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=onepiece_db

# ===================
# REDIS (Caching)
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===================
# AUTHENTICATION
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ===================
# SEED (first admin user — prisma/seed.js)
# ===================
# Set once to create a User row (username + bcrypt hash in DB). Remove after bootstrap if desired.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-in-production

# ===================
# AWS (Production)
# ===================
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:onepiece-api-secrets-xxxxx

# ===================
# RATE LIMITING
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================
# LOGGING
# ===================
LOG_LEVEL=info
LOG_HTTP_REQUESTS=false